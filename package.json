{
  "name": "bfs-timesheet-demo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:push": "drizzle-kit generate && tsx lib/db/apply.ts",
